{
  "name": "stuntdouble-vscode",
  "displayName": "StuntDouble Agent Sandbox",
  "description": "Invisibly wraps VS Code AI agents (Copilot, Cursor) inside the StuntDouble Sandbox",
  "version": "1.0.0",
  "publisher": "stuntdouble",
  "engines": {
    "vscode": "^1.90.0"
  },
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "stuntdouble.toggleIsolation",
        "title": "StuntDouble: Toggle Sandbox Isolation"
      }
    ]
  }
}
